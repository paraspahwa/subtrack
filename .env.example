# ─────────────────────────────────────────────
# SubTrack — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Database ──────────────────────────────────
# Option A: Supabase (recommended for production)
#   Dashboard → Project → Settings → Database → Connection string → Session mode
#   Use port 5432 (Session mode), NOT 6543 (Transaction mode) — required for SQLAlchemy
#   For Docker Compose backend, set BACKEND_DATABASE_URL to this value.
DATABASE_URL=postgresql://postgres:password@db:5432/subtrack

# Optional override used by docker-compose backend service.
# Leave empty for local docker postgres (default).
# Example:
# BACKEND_DATABASE_URL=postgresql://postgres:password@db.qedtzwskrsovslnixvju.supabase.co:5432/postgres
BACKEND_DATABASE_URL=

# Option B: Local PostgreSQL (docker-compose spins this up automatically)
# DATABASE_URL=postgresql://subtrack:subtrack@db:5432/subtrack

# ── Auth ──────────────────────────────────────
# Generate a secure secret: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# JWT token lifetime (seconds). Default: 86400 = 24 hours
ACCESS_TOKEN_EXPIRE_SECONDS=86400

# Password reset behavior
# false (recommended): never return reset token in API response; deliver by email provider
# true (dev only): include reset_token in forgot-password response
RETURN_RESET_TOKEN=false

# Reset token expiry (minutes)
RESET_TOKEN_EXPIRE_MINUTES=60

# Frontend reset route used in email links (optional)
# Example: https://subtrack.app/reset-password
RESET_PASSWORD_URL=

# SMTP settings for password reset email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# ── Razorpay ──────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use TEST keys for development, LIVE keys for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── App ───────────────────────────────────────
# CORS: Restrict to your domain(s) in production (comma-separated)
# Example: https://subtrack.app,https://www.subtrack.app
ALLOWED_ORIGINS=*

# Price anomaly alert threshold percentage for Action Center notifications.
# Minimum effective value is 1.0 even if a lower/non-positive value is configured.
PRICE_CHANGE_ALERT_THRESHOLD_PCT=10.0

# Frontend web fallback URL for mobile builds without native Razorpay module (e.g. Expo Go)
# Example: https://subtrack.app/pricing
EXPO_PUBLIC_WEB_UPGRADE_URL=
